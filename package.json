{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "setup-local": "node ./scripts/setup-local.mjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:web": "pnpm --filter @workspace/football-training-board build",
    "build:api": "pnpm --filter @workspace/api-server build",
    "start:api": "pnpm --filter @workspace/api-server start",
    "db:push": "pnpm --filter @workspace/db push",
    "dev:api:local": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-api-local.ps1",
    "dev:web:local": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-web-local.ps1",
    "dev:cursor:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-cursor-stack.ps1",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
